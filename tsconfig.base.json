{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@api/*": ["./apps/api/src/*"],
      "@web/*": ["./apps/web/src/*"],
      "@mobile/*": ["./apps/mobile/src/*"],
      "@schemas": ["./packages/schemas/src/index.ts"],
      "@schemas/*": ["./packages/schemas/src/*"]
    }
  }
}
